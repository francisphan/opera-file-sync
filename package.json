{
  "name": "opera-file-sync",
  "version": "1.0.0",
  "description": "Standalone script to sync OPERA file exports to Salesforce",
  "main": "opera-db-sync.js",
  "scripts": {
    "start": "node opera-db-sync.js",
    "test": "node --test tests/test-guest-utils.js tests/test-unit-core.js",
    "test:integration": "node tests/test-connection.js",
    "test:oracle": "node tests/test-oracle-connection.js",
    "test:notifications": "node tests/test-notifications.js",
    "dry-run": "node scripts/dry-run.js",
    "dry-run:verbose": "node scripts/dry-run.js --verbose",
    "dry-run:email": "node scripts/dry-run.js --email",
    "report:duplicates": "node scripts/duplicate-report.js",
    "report:duplicates:send": "node scripts/duplicate-report.js --send",
    "prebuild": "rm -rf node_modules && npm ci --omit=dev",
    "postbuild": "npm install",
    "build": "npm run prebuild && npx -y @yao-pkg/pkg opera-db-sync.js --targets node20-win-x64 --output dist/opera-sync-db.exe && npm run postbuild"
  },
  "pkg": {
    "assets": [
      "node_modules/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "opera",
    "salesforce",
    "pms",
    "sync",
    "integration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.4.5",
    "jsforce": "^3.10.14",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.1",
    "oracledb": "^6.10.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.0",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "open": "^8.4.0"
  }
}
